# Python
__pycache__/
*.pyc
.venv/

# PyInstaller build output (regenerated by CI / `pyinstaller LabelSorter.spec`)
build/
dist/

# Local dev state (mirrors what app_data_dir() would hold on a real machine)
_data/
*.local.json

# Test script output (tests/*.py write PDFs here to eyeball, not fixtures to keep)
tests/_output/

# OS cruft
.DS_Store
Thumbs.db
